%%--- Frame box helpers ---%%
% \@frametitlerule{title}: title rule spanning full text width (zero height via \smash)
\def\@frametitlerule#1{%
  \smash{\raisebox{-.5mm}{\hbox to .992\textwidth{%
    \Hrulefill\kern1mm\smash{\raisebox{-1mm}{\large\bf #1}}\kern1mm\Hrulefill%
  }}}%
}

% \@customfbox{top}{bottom}{content}
% Draws a framed box with configurable top and bottom elements.
%   top/bottom: \hrule\@height\fboxrule for a plain rule,
%               \@frametitlerule{...} for a title rule, or {} for none.
\long\def\@customfbox#1#2#3{%
  \leavevmode\setbox\@tempboxa\hbox{#3}%
  \@tempdima\fboxrule
  \advance\@tempdima\fboxsep
  \advance\@tempdima\dp\@tempboxa
  \hbox{\lower\@tempdima\hbox{\vbox{%
    #1%
    \hbox{%
      \vrule\@width\fboxrule\hskip\fboxsep
      \vbox{\vskip\fboxsep\box\@tempboxa\vskip\fboxsep}%
      \hskip\fboxsep\vrule\@width\fboxrule%
    }%
    #2%
  }}}%
}

% \@framecontent{extra-top-space}{content}
% Standard minipage wrapper used inside framed box environments.
\long\def\@framecontent#1#2{%
  \hspace*{1ex}%
  \begin{minipage}[t]{0.95\textwidth}%
    \vspace*{1ex}%
    #1%
    \hspace*{1zw}%
    #2%
    \vspace*{1.5ex}%
  \end{minipage}%
  \hspace*{1ex}%
}

% framesh: simple full-border frame
\newenvironment{framesh}[1]{%
  \noindent
  \@customfbox{\hrule\@height\fboxrule}{\hrule\@height\fboxrule}{%
    \@framecontent{}{#1}%
  }%
  \vspace*{.5\baselineskip}%
  \begingroup}{\endgroup}

% oneframesh: single-page titled frame (full border, ToC entry)
\newenvironment{oneframesh}[2]{%
  \addcontentsline{toc}{subsection}{\protect\small コラム\quad #1}%
  \small
  \noindent
  \@customfbox{\@frametitlerule{#1}}{\hrule\@height\fboxrule}{%
    \@framecontent{\vspace*{\baselineskip}}{#2}%
  }%
  \vspace*{.5\baselineskip}%
  \begingroup}{\endgroup}






% bframesh: multi-page titled frame -- beginning (title rule, no bottom)
\newenvironment{bframesh}[2]{%
  \addcontentsline{toc}{subsection}{\protect\small コラム\quad #1}%
  \small
  \noindent
  \@customfbox{\@frametitlerule{#1}}{}{%
    \@framecontent{\vspace*{\baselineskip}}{#2}%
  }%
  \vspace*{.5\baselineskip}%
  \begingroup}{\endgroup}

% tframesh: multi-page titled frame -- ending (no top, bottom rule)
\newenvironment{tframesh}[1]{%
  \small
  \noindent
  \@customfbox{}{\hrule\@height\fboxrule}{%
    \@framecontent{}{#1}%
  }%
  \vspace*{.5\baselineskip}%
  \begingroup}{\endgroup}

% cframesh: multi-page titled frame -- middle (no top, no bottom)
\newenvironment{cframesh}[1]{%
  \small
  \noindent
  \@customfbox{}{}{%
    \@framecontent{}{#1}%
  }%
  \vspace*{.5\baselineskip}%
  \begingroup}{\endgroup}
